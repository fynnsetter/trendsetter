WATCHLIST_FILE = 'watchlist.json'

def load_watchlist():
    if os.path.exists(WATCHLIST_FILE):
        try:
            with open(WATCHLIST_FILE, 'r') as f:
                return json.load(f)
        except:
            return ["NVDA", "AAPL", "GOOGL", "TSLA"]
    return ["NVDA", "AAPL", "GOOGL", "TSLA"]

def save_watchlist(wlist):
    with open(WATCHLIST_FILE, 'w') as f:
        json.dump(wlist, f)

